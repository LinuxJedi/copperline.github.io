ype":"paragraph","children":[{"type":"strong","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"children":[{"type":"text","value":"Determinism.","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"key":"XsWkD03186"}],"key":"yRRqubtza2"},{"type":"text","value":" The emulated core is deterministic and independent of\nthe host: a headless unthrottled run and a real-time windowed run produce\nthe same emulated result when given the same inputs and media. That is\nwhat makes headless captures reproducible, and it is also what lets the\ndebugger step backwards.","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"key":"hrwjOMYDbZ"}],"key":"UXWtzHIKFL"}],"key":"YX9LmGTjzJ"}],"key":"oG8gUXUmxf"}],"key":"MVKP8qiYcI"}],"key":"e8sgWktqai"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"next":{"title":"Getting started","url":"/getting-started","group":"User guide"}}},"domain":"http://localhost:3000"}