d result when given the same inputs and media. That is\nwhat makes headless captures reproducible, and it is also what lets the\ndebugger step backwards.","position":{"start":{"line":60,"column":1},"end":{"line":60,"column":1}},"key":"Bk8w9KIA5k"}],"key":"SRIKCfqRNQ"}],"key":"CSphQ5GPnc"}],"key":"PHMUxg8wOT"}],"key":"tVgsfsZxr4"}],"key":"Dym97jET34"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"next":{"title":"Getting started","url":"/getting-started","group":"User guide"}}},"domain":"http://localhost:3000"}